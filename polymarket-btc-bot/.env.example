# ============================================================
# Configuración del Bot de Trading Polymarket BTC Up/Down 5m
# ============================================================
# Copia este archivo a .env y completa los valores.
# NUNCA subas el archivo .env a Git.

# ------------------------------------------------------------
# CREDENCIALES DE POLYMARKET (solo necesarias en PRODUCTION)
# ------------------------------------------------------------

# Clave privada de tu wallet de Polygon (sin 0x)
PRIVATE_KEY=

# Dirección del proxy de Polymarket asociado a tu cuenta
POLYMARKET_PROXY_ADDRESS=

# Tipo de firma: 0 = EOA, 1 = EIP-1271, 2 = Polymarket proxy
SIGNATURE_TYPE=0

# ------------------------------------------------------------
# MODO DE OPERACIÓN
# ------------------------------------------------------------

# true = ejecuta órdenes reales en Polymarket
# false = solo simula (recomendado para pruebas)
PRODUCTION=false

# true = simula todas las órdenes sin enviarlas (ignora PRODUCTION)
DRY_RUN=true

# ------------------------------------------------------------
# PARÁMETROS DE TRADING
# ------------------------------------------------------------

# Monto a apostar por trade en USDC
BET_AMOUNT_USDC=5.0

# Confianza mínima de la señal para operar (0.0 a 1.0)
# 0.65 = 65% de confianza mínima requerida
MIN_CONFIDENCE=0.65

# Precio mínimo del token para operar (odds mínimas)
# Un token a 0.55 implica que el mercado da 45% de chance al contrario
MIN_ODDS=0.55

# Precio máximo del token para operar (odds máximas)
# Tokens muy caros (>0.92) tienen poca ganancia potencial
MAX_ODDS=0.92

# Segundos antes del cierre de la ventana para entrar al trade
ENTRY_SECONDS_BEFORE=25

# ------------------------------------------------------------
# GESTIÓN DE RIESGO
# ------------------------------------------------------------

# Máximo de trades por hora (rate limiting)
MAX_TRADES_PER_HOUR=12

# Stop-loss diario en USD: el bot se detiene si pierde este monto en un día
STOP_LOSS_DAILY_USD=20.0

# ------------------------------------------------------------
# LATENCY SNIPER (estrategia de sniper por movimiento rápido)
# ------------------------------------------------------------

# Umbral de movimiento de precio en % para activar el sniper (ej: 0.08 = 0.08%)
SNIPER_THRESHOLD=0.08

# Segundos mínimos restantes en la ventana para que el sniper pueda actuar
SNIPER_MIN_SECONDS_LEFT=60

# ------------------------------------------------------------
# NOTIFICACIONES TELEGRAM (opcional)
# ------------------------------------------------------------

# Token del bot de Telegram (obtener desde @BotFather)
TELEGRAM_BOT_TOKEN=

# ID del chat donde enviar notificaciones (obtener desde @userinfobot)
TELEGRAM_CHAT_ID=
